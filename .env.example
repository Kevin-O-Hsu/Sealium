# ==========================================================================
# Sealium 敏感配置示例（环境变量 / dotenv）
# ==========================================================================
# 复制为 .env（已被 .gitignore 忽略，不会入库），填入真实值。
# 这些变量优先级高于 sealium.toml，适合放敏感项与部署差异。
#
# 命名规则：SEALIUM_<SECTION>__<KEY>（双下划线分隔嵌套）。
# 也可直接在系统环境变量 / systemd EnvironmentFile / 容器 env 中设置同名变量。
# ==========================================================================

# 服务端私钥落盘口令（须与 `python -m sealium.scripts.generate_keys --passphrase` 一致）。
# 留空则私钥明文存储（仅兼容无口令场景，不推荐用于生产）。
SEALIUM_SECURITY__PRIVATE_KEY_PASSPHRASE=change-me-to-a-long-random-string

# —— 以下为可选覆盖项示例（均可在 sealium.toml 配置，这里仅作部署差异覆盖）——
# SEALIUM_SERVER__HOST=127.0.0.1
# SEALIUM_SERVER__PORT=8000
# SEALIUM_SERVER__DEBUG=false
