# ==========================================================================
# Sealium 服务端配置文件（示例）
# ==========================================================================
# 复制本文件为 sealium.toml 并按需修改。sealium.toml 已被 .gitignore 忽略，
# 不会入库；本 .example 文件作为 schema 文档随仓库分发。
#
# 配置优先级（从高到低，前者覆盖后者）：
#   1. 构造参数（程序化注入，测试用）
#   2. 环境变量  SEALIUM_<SECTION>__<KEY>   例: SEALIUM_SERVER__PORT=9000
#   3. .env 文件 （同 2 语义，用于本地开发 / 敏感项）
#   4. 本文件 sealium.toml（结构化主配置）
#   4. 内置默认值
#
# 重要：
#   * 敏感项（私钥口令）放 .env 或环境变量，【不要】写进本文件。
#   * 路径若为相对路径，相对本文件所在目录解析（部署可整体搬迁）。
#   * 无 sealium.toml 也能启动（零配置开箱即用）；本文件仅作覆盖。
# ==========================================================================

[server]
# 监听地址。生产建议 127.0.0.1（置于反向代理 / 防火墙之后）。
host = "0.0.0.0"
port = 8000
# 调试模式：开启 /docs /redoc /openapi.json 与 /debug/config，并启用热重载。
# 生产必须 false（避免泄露接口结构）。
debug = false
# API 前缀与激活路径；完整激活路由 = api_prefix + activation_path（默认 /v1/activation）
api_prefix = "/v1"
activation_path = "/activation"

[paths]
# SQLite 数据库与服务端 RSA 私钥路径。相对路径相对本文件目录。
database = "data/database.db"
private_key = "data/server_private.pem"
# public_key = "data/server_public.pem"   # 可选，仅调试用

[security]
# 客户端时间戳允许偏差（秒）；超此拒绝（防伪造 / 过期请求）。
timestamp_tolerance_seconds = 300
# 防重放 (code, nonce) 缓存容量（LRU + TTL 逐条淘汰）。
replay_cache_size = 10000
# 私钥落盘口令：【不要写在这里】。放 .env：
#   SEALIUM_SECURITY__PRIVATE_KEY_PASSPHRASE=your-long-random-passphrase
# 留空（默认）则私钥明文存储，仅兼容无口令场景，不推荐用于生产。

[rate_limit]
# 进程内固定窗口限流（按客户端 IP 聚合）。超限返回 429 + Retry-After。
# 多 worker 部署下各进程独立计数（弱一致）；需全局精确请注入共享后端（如 Redis）。
enabled = true
max_requests = 60        # 每窗口每 IP 最大请求数
window_seconds = 60      # 窗口大小（秒）

[machine_id]
# 同机判定策略（详见 docs/hardware-binding.md）。
# 调宽（更易认同一台机器，但防破解变弱）：降 threshold / core_min。
# 调严（换一点硬件就要重激活，防破解更强）：提高之。
# 注意：改这些会让已绑定记录的判定结果变化，一般不在运行中调整。
threshold = 0.70   # 加权相似度门槛
core_min = 3       # 核心类（cpu/board/bios/system_uuid）至少匹配几个
spoof_max = 0.5    # spoof_score 超此直接判异机

[logging]
# 日志级别按“用户能否直接感知”分级：INFO 仅关键里程碑，DEBUG 记录细节。
level = "INFO"
format = "%(asctime)s - %(name)s - %(levelname)s - %(message)s"

[cors]
# TOML 数组语法。原生客户端（application/octet-stream）无需浏览器凭据；
# allow_credentials 已在应用层关闭，避免 “* + credentials” 误配。
origins = ["*"]
